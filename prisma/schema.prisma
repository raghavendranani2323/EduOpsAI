generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// CORE — Auth + Tenancy
// ─────────────────────────────────────────────

model Profile {
  id            String   @id // = auth.users.id
  fullName      String
  phone         String?
  email         String?
  avatarUrl     String?
  designation   String?
  qualification String?
  joinedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships       Membership[]
  markedSessions    AttendanceSession[]
  recordedPayments  Payment[]
  classHeadFor      ClassGroup[]        @relation("ClassHead")
  sectionTeacherFor Class[]             @relation("SectionTeacher")
  teacherSubjects   TeacherSubject[]

  @@map("profiles")
}

model TeacherSubject {
  id        String  @id @default(cuid())
  profileId String
  subjectId String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([profileId, subjectId])
  @@index([subjectId])
  @@map("teacher_subjects")
}

model Institution {
  id                   String          @id @default(cuid())
  name                 String
  type                 InstitutionType @default(SCHOOL)
  city                 String
  state                String
  board                String?
  affiliationNo        String?
  phone                String?
  addressLine1         String?
  addressLine2         String?
  pincode              String?
  principalName        String?
  gstNumber            String?
  logoUrl              String?
  receiptPrefix        String?         @default("INV")
  receiptCounter       Int             @default(0)
  siblingDiscounts     Json?
  isDemo               Boolean         @default(false)
  terminologyOverrides Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  memberships    Membership[]
  invitations    Invitation[]
  academicYears  AcademicYear[]
  classGroups    ClassGroup[]
  classes        Class[]
  students       Student[]
  guardians      Guardian[]
  tags           Tag[]
  sessions       AttendanceSession[]
  feePlans       FeePlan[]
  feeAdjustments FeeAdjustment[]
  invoices       Invoice[]
  payments       Payment[]
  leads          Lead[]
  templates      MessageTemplate[]
  messages       Message[]
  subjects       Subject[]
  exams          Exam[]
  examResults    ExamResult[]
  timetableSlots TimetableSlot[]
  homework       Homework[]
  notices        Notice[]
  leaveRequests  LeaveRequest[]

  @@map("institutions")
}

enum InstitutionType {
  SCHOOL
  COACHING
  PRESCHOOL
  TUITION
}

model Membership {
  id            String    @id @default(cuid())
  userId        String
  institutionId String
  role          Role      @default(TEACHER)
  invitedBy     String?
  acceptedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  user        Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([userId, institutionId])
  @@map("memberships")
}

enum Role {
  OWNER
  ADMIN
  TEACHER
  ACCOUNTANT
}

model Invitation {
  id            String    @id @default(cuid())
  institutionId String
  email         String
  role          Role      @default(TEACHER)
  token         String    @unique @default(cuid())
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

// ─────────────────────────────────────────────
// ACADEMIC — Classes + Students
// ─────────────────────────────────────────────

model AcademicYear {
  id            String    @id @default(cuid())
  institutionId String
  name          String
  startsOn      DateTime? @db.Date
  endsOn        DateTime? @db.Date
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  classGroups ClassGroup[]
  classes     Class[]
  feePlans    FeePlan[]

  @@unique([institutionId, name])
  @@map("academic_years")
}

model ClassGroup {
  id             String   @id @default(cuid())
  institutionId  String
  academicYearId String?
  name           String
  medium         String?
  classHeadId    String?
  classLeaderId  String?
  girlsLeaderId  String?
  boysLeaderId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  institution  Institution   @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  classHead    Profile?      @relation("ClassHead", fields: [classHeadId], references: [id], onDelete: SetNull)
  classLeader  Student?      @relation("ClassGroupLeader", fields: [classLeaderId], references: [id], onDelete: SetNull)
  girlsLeader  Student?      @relation("ClassGroupGirlsLeader", fields: [girlsLeaderId], references: [id], onDelete: SetNull)
  boysLeader   Student?      @relation("ClassGroupBoysLeader", fields: [boysLeaderId], references: [id], onDelete: SetNull)
  sections     Class[]

  @@unique([institutionId, academicYearId, name])
  @@map("class_groups")
}

model Class {
  id               String   @id @default(cuid())
  institutionId    String
  classGroupId     String?
  academicYearId   String?
  name             String
  section          String?
  medium           String?
  academicYear     String
  sectionTeacherId String?
  sectionLeaderId  String?
  girlsLeaderId    String?
  boysLeaderId     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution     Institution         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  classGroup      ClassGroup?         @relation(fields: [classGroupId], references: [id], onDelete: SetNull)
  academicYearRef AcademicYear?       @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  sectionTeacher  Profile?            @relation("SectionTeacher", fields: [sectionTeacherId], references: [id], onDelete: SetNull)
  sectionLeader   Student?            @relation("SectionLeader", fields: [sectionLeaderId], references: [id], onDelete: SetNull)
  girlsLeader     Student?            @relation("SectionGirlsLeader", fields: [girlsLeaderId], references: [id], onDelete: SetNull)
  boysLeader      Student?            @relation("SectionBoysLeader", fields: [boysLeaderId], references: [id], onDelete: SetNull)
  students        Student[]
  sessions        AttendanceSession[]
  feePlans        FeePlan[]
  subjects        Subject[]
  exams           Exam[]
  timetableSlots  TimetableSlot[]
  homework        Homework[]

  @@map("classes")
}

model Student {
  id            String        @id @default(cuid())
  institutionId String
  fullName      String
  admissionNo   String?
  dob           DateTime?
  gender        Gender?
  classId       String?
  status        StudentStatus @default(ACTIVE)
  archivedAt    DateTime?
  portalToken   String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution              Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class                    Class?             @relation(fields: [classId], references: [id])
  guardians                StudentGuardian[]
  studentTags              StudentTag[]
  attendanceRecords        AttendanceRecord[]
  invoices                 Invoice[]
  feeAdjustments           FeeAdjustment[]
  leads                    Lead[]             @relation("ConvertedStudent")
  examResults              ExamResult[]
  classGroupLeaderFor      ClassGroup[]       @relation("ClassGroupLeader")
  classGroupGirlsLeaderFor ClassGroup[]       @relation("ClassGroupGirlsLeader")
  classGroupBoysLeaderFor  ClassGroup[]       @relation("ClassGroupBoysLeader")
  sectionLeaderFor         Class[]            @relation("SectionLeader")
  sectionGirlsLeaderFor    Class[]            @relation("SectionGirlsLeader")
  sectionBoysLeaderFor     Class[]            @relation("SectionBoysLeader")

  @@map("students")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  ARCHIVED
}

model Guardian {
  id            String   @id @default(cuid())
  institutionId String
  fullName      String
  phone         String
  email         String?
  createdAt     DateTime @default(now())

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  students    StudentGuardian[]

  @@map("guardians")
}

model StudentGuardian {
  studentId  String
  guardianId String
  relation   String  @default("parent")
  isPrimary  Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

model Tag {
  id            String @id @default(cuid())
  institutionId String
  label         String
  color         String @default("#6366f1")

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  studentTags StudentTag[]

  @@unique([institutionId, label])
  @@map("tags")
}

model StudentTag {
  studentId String
  tagId     String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([studentId, tagId])
  @@map("student_tags")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model AttendanceSession {
  id            String   @id @default(cuid())
  institutionId String
  classId       String
  sessionDate   DateTime @db.Date
  sessionLabel  String   @default("morning")
  markedBy      String
  markedAt      DateTime @default(now())

  institution Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  marker      Profile            @relation(fields: [markedBy], references: [id])
  records     AttendanceRecord[]

  @@unique([classId, sessionDate, sessionLabel])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus @default(PRESENT)
  note      String?

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ─────────────────────────────────────────────
// FEES
// ─────────────────────────────────────────────

model FeePlan {
  id               String   @id @default(cuid())
  institutionId    String
  academicYearId   String?
  name             String
  amount           Int // total in paise (sum of components, or legacy single value)
  cadence          Cadence  @default(MONTHLY)
  lateFeeAmount    Int      @default(0)
  lateFeePercent   Int      @default(0) // basis points, 250 = 2.5%
  lateFeeAfterDays Int      @default(10)
  classId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution  Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear?      @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  class        Class?             @relation(fields: [classId], references: [id])
  invoices     Invoice[]
  components   FeePlanComponent[]

  @@index([institutionId, academicYearId])
  @@map("fee_plans")
}

model FeePlanComponent {
  id         String   @id @default(cuid())
  planId     String
  name       String
  amount     Int      // paise
  isOptional Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  plan FeePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("fee_plan_components")
}

enum Cadence {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

model FeeAdjustment {
  id            String         @id @default(cuid())
  institutionId String
  studentId     String
  kind          AdjustmentKind
  amount        Int // in paise; negative = discount
  reason        String?
  validFrom     DateTime?
  validTo       DateTime?
  createdAt     DateTime       @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("fee_adjustments")
}

enum AdjustmentKind {
  SIBLING_DISCOUNT
  SCHOLARSHIP
  WAIVER
  EXTRA_CHARGE
}

model Invoice {
  id            String        @id @default(cuid())
  institutionId String
  studentId     String
  feePlanId     String?
  periodStart   DateTime?     @db.Date
  periodEnd     DateTime?     @db.Date
  amountDue     Int // in paise
  amountPaid    Int           @default(0)
  status        InvoiceStatus @default(UNPAID)
  dueDate       DateTime      @db.Date
  receiptNumber String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feePlan     FeePlan?    @relation(fields: [feePlanId], references: [id])
  payments    Payment[]

  @@index([institutionId, studentId, feePlanId, periodStart], name: "invoices_dedupe_idx")
  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

model Payment {
  id                        String      @id @default(cuid())
  institutionId             String
  invoiceId                 String
  amount                    Int // in paise
  mode                      PaymentMode @default(CASH)
  referenceNo               String?
  paidAt                    DateTime
  recordedBy                String
  razorpayOrderId           String?
  razorpayPaymentId         String?     @unique
  razorpaySignatureVerified Boolean     @default(false)
  receiptSharedAt           DateTime?
  createdAt                 DateTime    @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recorder    Profile     @relation(fields: [recordedBy], references: [id])

  @@map("payments")
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

// ─────────────────────────────────────────────
// ADMISSIONS CRM
// ─────────────────────────────────────────────

model Lead {
  id                   String     @id @default(cuid())
  institutionId        String
  studentName          String
  guardianName         String
  phone                String
  interestedClass      String?
  source               LeadSource @default(WALK_IN)
  priority             Priority   @default(WARM)
  stage                LeadStage  @default(NEW)
  nextFollowupAt       DateTime?
  lastNote             String?
  convertedToStudentId String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  institution      Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  convertedStudent Student?    @relation("ConvertedStudent", fields: [convertedToStudentId], references: [id])

  @@map("leads")
}

enum LeadSource {
  WALK_IN
  PHONE
  INSTAGRAM
  WHATSAPP
  REFERRAL
  WEBSITE
}

enum Priority {
  HOT
  WARM
  COLD
}

enum LeadStage {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_ATTENDED
  CONVERTED
  LOST
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

model MessageTemplate {
  id            String       @id @default(cuid())
  institutionId String
  kind          TemplateKind
  language      String       @default("en")
  body          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("message_templates")
}

enum TemplateKind {
  FEE_REMINDER
  ABSENCE
  EXAM_SCORE
  BIRTHDAY
  HOMEWORK
  CUSTOM
}

model Message {
  id                String        @id @default(cuid())
  institutionId     String
  recipientPhone    String
  channel           Channel       @default(WHATSAPP)
  templateId        String?
  body              String
  status            MessageStatus @default(DRAFT)
  providerMessageId String?
  sentAt            DateTime?
  failureReason     String?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  institution Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  template    MessageTemplate? @relation(fields: [templateId], references: [id])

  @@map("messages")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// ─────────────────────────────────────────────
// PHASE 2 — EXAMS & MARKS
// ─────────────────────────────────────────────

model Subject {
  id            String   @id @default(cuid())
  institutionId String
  classId       String?
  name          String
  code          String?
  createdAt     DateTime @default(now())

  institution     Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class           Class?           @relation(fields: [classId], references: [id])
  examResults     ExamResult[]
  teacherSubjects TeacherSubject[]

  @@map("subjects")
}

model Exam {
  id            String    @id @default(cuid())
  institutionId String
  classId       String?
  name          String
  examDate      DateTime?
  totalMarks    Int       @default(100)
  passingMarks  Int       @default(35)
  academicYear  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class?       @relation(fields: [classId], references: [id])
  results     ExamResult[]

  @@map("exams")
}

model ExamResult {
  id            String   @id @default(cuid())
  institutionId String
  examId        String
  studentId     String
  subjectId     String
  marksObtained Float?
  grade         String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subjectId])
  @@map("exam_results")
}

// ─────────────────────────────────────────────
// PHASE 2 — TIMETABLE
// ─────────────────────────────────────────────

model TimetableSlot {
  id            String  @id @default(cuid())
  institutionId String
  classId       String
  subjectId     String?
  teacherId     String?
  dayOfWeek     Int // 1=Mon … 7=Sun
  startTime     String // "09:00"
  endTime       String // "09:45"
  label         String? // "Math Period 1"

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class       @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("timetable_slots")
}

// ─────────────────────────────────────────────
// PHASE 2 — HOMEWORK
// ─────────────────────────────────────────────

model Homework {
  id            String    @id @default(cuid())
  institutionId String
  classId       String
  subjectId     String?
  teacherId     String
  title         String
  description   String?
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class       @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("homework")
}

// ─────────────────────────────────────────────
// PHASE 2 — NOTICE BOARD
// ─────────────────────────────────────────────

model Notice {
  id            String         @id @default(cuid())
  institutionId String
  authorId      String
  title         String
  body          String
  audience      NoticeAudience @default(ALL)
  classId       String?
  pinned        Boolean        @default(false)
  publishedAt   DateTime       @default(now())
  expiresAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  reads       NoticeRead[]

  @@map("notices")
}

model NoticeRead {
  id        String   @id @default(cuid())
  noticeId  String
  studentId String
  readAt    DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@unique([noticeId, studentId])
  @@index([studentId])
  @@map("notice_reads")
}

enum NoticeAudience {
  ALL
  TEACHERS
  PARENTS
  CLASS
}

// ─────────────────────────────────────────────
// PHASE 2 — STAFF LEAVE
// ─────────────────────────────────────────────

model LeaveRequest {
  id            String      @id @default(cuid())
  institutionId String
  userId        String
  leaveType     LeaveType   @default(CASUAL)
  fromDate      DateTime
  toDate        DateTime
  reason        String?
  status        LeaveStatus @default(PENDING)
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────
// PUSH NOTIFICATIONS
// ─────────────────────────────────────────────

model PushSubscription {
  endpoint  String   @id
  userId    String?
  p256dh    String
  auth      String
  ua        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// AUDIT LOG — appendable trail
// ─────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId   String
  institutionId String?
  action        String
  targetId      String?
  meta          Json?
  createdAt     DateTime @default(now())

  @@index([institutionId, createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}
