generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// CORE — Auth + Tenancy
// ─────────────────────────────────────────────

model Profile {
  id        String   @id // = auth.users.id
  fullName  String
  phone     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  markedSessions AttendanceSession[]
  recordedPayments Payment[]

  @@map("profiles")
}

model Institution {
  id                  String          @id @default(cuid())
  name                String
  type                InstitutionType @default(SCHOOL)
  city                String
  state               String
  board               String?
  affiliationNo       String?
  isDemo              Boolean         @default(false)
  terminologyOverrides Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  memberships  Membership[]
  invitations  Invitation[]
  classes      Class[]
  students     Student[]
  guardians    Guardian[]
  tags         Tag[]
  sessions     AttendanceSession[]
  feePlans     FeePlan[]
  feeAdjustments FeeAdjustment[]
  invoices     Invoice[]
  payments     Payment[]
  leads        Lead[]
  templates    MessageTemplate[]
  messages     Message[]

  @@map("institutions")
}

enum InstitutionType {
  SCHOOL
  COACHING
  PRESCHOOL
  TUITION
}

model Membership {
  id            String    @id @default(cuid())
  userId        String
  institutionId String
  role          Role      @default(TEACHER)
  invitedBy     String?
  acceptedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  user        Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@unique([userId, institutionId])
  @@map("memberships")
}

enum Role {
  OWNER
  ADMIN
  TEACHER
  ACCOUNTANT
}

model Invitation {
  id            String    @id @default(cuid())
  institutionId String
  email         String
  role          Role      @default(TEACHER)
  token         String    @unique @default(cuid())
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

// ─────────────────────────────────────────────
// ACADEMIC — Classes + Students
// ─────────────────────────────────────────────

model Class {
  id            String   @id @default(cuid())
  institutionId String
  name          String
  section       String?
  academicYear  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  students    Student[]
  sessions    AttendanceSession[]
  feePlans    FeePlan[]

  @@map("classes")
}

model Student {
  id            String        @id @default(cuid())
  institutionId String
  fullName      String
  admissionNo   String?
  dob           DateTime?
  gender        Gender?
  classId       String?
  status        StudentStatus @default(ACTIVE)
  archivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution    Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class          Class?           @relation(fields: [classId], references: [id])
  guardians      StudentGuardian[]
  studentTags    StudentTag[]
  attendanceRecords AttendanceRecord[]
  invoices       Invoice[]
  feeAdjustments FeeAdjustment[]
  leads          Lead[]           @relation("ConvertedStudent")

  @@map("students")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  ARCHIVED
}

model Guardian {
  id            String  @id @default(cuid())
  institutionId String
  fullName      String
  phone         String
  email         String?
  createdAt     DateTime @default(now())

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  students    StudentGuardian[]

  @@map("guardians")
}

model StudentGuardian {
  studentId  String
  guardianId String
  relation   String  @default("parent")
  isPrimary  Boolean @default(false)

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

model Tag {
  id            String @id @default(cuid())
  institutionId String
  label         String
  color         String @default("#6366f1")

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  studentTags StudentTag[]

  @@unique([institutionId, label])
  @@map("tags")
}

model StudentTag {
  studentId String
  tagId     String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([studentId, tagId])
  @@map("student_tags")
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model AttendanceSession {
  id            String   @id @default(cuid())
  institutionId String
  classId       String
  sessionDate   DateTime @db.Date
  sessionLabel  String   @default("morning")
  markedBy      String
  markedAt      DateTime @default(now())

  institution Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  marker      Profile            @relation(fields: [markedBy], references: [id])
  records     AttendanceRecord[]

  @@unique([classId, sessionDate, sessionLabel])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus @default(PRESENT)
  note      String?

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@map("attendance_records")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ─────────────────────────────────────────────
// FEES
// ─────────────────────────────────────────────

model FeePlan {
  id               String  @id @default(cuid())
  institutionId    String
  name             String
  amount           Int     // in paise (₹1 = 100 paise)
  cadence          Cadence @default(MONTHLY)
  lateFeeAmount    Int     @default(0)
  lateFeeAfterDays Int     @default(10)
  classId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  class       Class?       @relation(fields: [classId], references: [id])
  invoices    Invoice[]

  @@map("fee_plans")
}

enum Cadence {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

model FeeAdjustment {
  id            String         @id @default(cuid())
  institutionId String
  studentId     String
  kind          AdjustmentKind
  amount        Int            // in paise; negative = discount
  reason        String?
  validFrom     DateTime?
  validTo       DateTime?
  createdAt     DateTime       @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("fee_adjustments")
}

enum AdjustmentKind {
  SIBLING_DISCOUNT
  SCHOLARSHIP
  WAIVER
  EXTRA_CHARGE
}

model Invoice {
  id            String        @id @default(cuid())
  institutionId String
  studentId     String
  feePlanId     String?
  periodStart   DateTime?     @db.Date
  periodEnd     DateTime?     @db.Date
  amountDue     Int           // in paise
  amountPaid    Int           @default(0)
  status        InvoiceStatus @default(UNPAID)
  dueDate       DateTime      @db.Date
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feePlan     FeePlan?     @relation(fields: [feePlanId], references: [id])
  payments    Payment[]

  @@map("invoices")
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

model Payment {
  id                       String      @id @default(cuid())
  institutionId            String
  invoiceId                String
  amount                   Int         // in paise
  mode                     PaymentMode @default(CASH)
  referenceNo              String?
  paidAt                   DateTime
  recordedBy               String
  razorpayOrderId          String?
  razorpayPaymentId        String?     @unique
  razorpaySignatureVerified Boolean    @default(false)
  createdAt                DateTime    @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recorder    Profile      @relation(fields: [recordedBy], references: [id])

  @@map("payments")
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

// ─────────────────────────────────────────────
// ADMISSIONS CRM
// ─────────────────────────────────────────────

model Lead {
  id                  String      @id @default(cuid())
  institutionId       String
  studentName         String
  guardianName        String
  phone               String
  interestedClass     String?
  source              LeadSource  @default(WALK_IN)
  priority            Priority    @default(WARM)
  stage               LeadStage   @default(NEW)
  nextFollowupAt      DateTime?
  lastNote            String?
  convertedToStudentId String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  institution       Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  convertedStudent  Student?    @relation("ConvertedStudent", fields: [convertedToStudentId], references: [id])

  @@map("leads")
}

enum LeadSource {
  WALK_IN
  PHONE
  INSTAGRAM
  WHATSAPP
  REFERRAL
  WEBSITE
}

enum Priority {
  HOT
  WARM
  COLD
}

enum LeadStage {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_ATTENDED
  CONVERTED
  LOST
}

// ─────────────────────────────────────────────
// COMMUNICATIONS
// ─────────────────────────────────────────────

model MessageTemplate {
  id            String          @id @default(cuid())
  institutionId String
  kind          TemplateKind
  language      String          @default("en")
  body          String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("message_templates")
}

enum TemplateKind {
  FEE_REMINDER
  ABSENCE
  EXAM_SCORE
  BIRTHDAY
  HOMEWORK
  CUSTOM
}

model Message {
  id                String        @id @default(cuid())
  institutionId     String
  recipientPhone    String
  channel           Channel       @default(WHATSAPP)
  templateId        String?
  body              String
  status            MessageStatus @default(DRAFT)
  providerMessageId String?
  sentAt            DateTime?
  failureReason     String?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  institution Institution      @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  template    MessageTemplate? @relation(fields: [templateId], references: [id])

  @@map("messages")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}
